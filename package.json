{
  "name": "dm-manager",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "generate": "node scripts/generate.js",
    "gen": "npm run generate",
    "dev": "npm run lint && next dev --turbopack",
    "build": "npm run lint && next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "dockerstart": "docker compose up -d",
    "dev:no-lint": "next dev --turbopack",
    "build:no-lint": "next build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@heroui/button": "^2.2.24",
    "@heroui/react": "^2.8.2",
    "@heroui/system": "^2.4.20",
    "@heroui/theme": "^2.4.20",
    "framer-motion": "^12.23.12",
    "mongodb": "^6.18.0",
    "next": "15.4.4",
    "postcss": "^8.5.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "zod": "^4.0.10"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.1.11",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9",
    "eslint-config-next": "15.4.4",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.1.11",
    "typescript": "^5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
