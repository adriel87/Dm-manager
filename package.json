{
  "name": "dm-manager",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "generate": "node scripts/generate.js",
    "gen": "npm run generate",
    "dev": "npm run dev --workspace=packages/app",
    "dev:no-lint": "npm run dev:no-lint --workspace=packages/app",
    "build": "npm run build --workspace=packages/app",
    "build:no-lint": "npm run build:no-lint --workspace=packages/app",
    "start": "npm run start --workspace=packages/app",
    "lint": "npm run lint --workspace=packages/app",
    "lint:fix": "npm run lint:fix --workspace=packages/app",
    "dockerstart": "docker compose up -d",
    "test": "npm run test --workspace=packages/app",
    "test:ui": "npm run test:ui --workspace=packages/app",
    "test:run": "npm run test:run --workspace=packages/app",
    "test:coverage": "npm run test:coverage --workspace=packages/app",
    "test:watch": "npm run test:watch --workspace=packages/app",
    "test:bot": "npm test --workspace=packages/bot",
    "test:all": "npm run test:run && npm run test:bot",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "PWDEBUG=1 playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  }
}
