# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=dungeon_master
MONGODB_USERNAME=dungeon_master
MONGODB_PASSWORD=dice_roller

# Repository implementation: "mongo" | "memory"
REPOSITORY_TYPE=mongo

# Discord identity for the DM — auto-populates DM row in Speaker Mapping modal
NEXT_PUBLIC_DM_DISCORD_USER_ID=
NEXT_PUBLIC_DM_DISCORD_USERNAME=

# Transcription provider: "whisper-api" | "whisper-local" | "transcription-service"
# Use "transcription-service" when running via Docker Compose (delegates to packages/transcription-service)
TRANSCRIPTION_PROVIDER=whisper-api

# Required when TRANSCRIPTION_PROVIDER=transcription-service
TRANSCRIPTION_SERVICE_URL=http://localhost:3002

# Required when TRANSCRIPTION_PROVIDER=whisper-api (or when transcription-service uses whisper-api internally)
OPENAI_API_KEY=

# Required when TRANSCRIPTION_PROVIDER=whisper-local
WHISPER_LOCAL_URL=http://localhost:8080
