# ============================================================
# Discord Bot Configuration
# ============================================================

# Bot token — from Discord Developer Portal > Bot > Token
DISCORD_TOKEN=

# Application ID — from Discord Developer Portal > General Information > Application ID
DISCORD_CLIENT_ID=

# Guild ID for dev command registration (faster than global, guild-scoped)
# Leave empty for global command registration (takes ~1h to propagate)
DISCORD_GUILD_ID=

# ============================================================
# DM Manager API
# ============================================================

# Base URL of the DM Manager Next.js app
DM_MANAGER_URL=http://localhost:3000

# Request timeout in milliseconds (default: 30000 for stop, 5000 for others)
DM_MANAGER_TIMEOUT_MS=30000

# ============================================================
# Recording
# ============================================================

# Safety cutoff — bot auto-stops recording after this many hours (default: 4)
MAX_RECORDING_HOURS=4

# ============================================================
# Logging
# ============================================================

# Log level: error | warn | info | debug (default: info)
LOG_LEVEL=info
