{
  "openapi": "3.0.1",
  "info": {
    "title": "DM Manager API",
    "description": "API for Dungeon Masters to manage campaigns, missions, characters, groups and sessions.",
    "version": "0.2.0"
  },
  "tags": [
    { "name": "campaigns" },
    { "name": "missions" },
    { "name": "characters" },
    { "name": "groups" },
    { "name": "sessions" },
    { "name": "seed" }
  ],
  "paths": {
    "/api/campaign": {
      "get": {
        "summary": "Get all campaigns",
        "tags": ["campaigns"],
        "responses": {
          "200": {
            "description": "List of campaigns",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Campaign" }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a campaign",
        "tags": ["campaigns"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CampaignInput" },
              "example": {
                "name": "La destruccion del anillo",
                "description": "Un grupo de aventureros tienen que destruir un anillo",
                "status": "Activa",
                "sessions": 0
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Campaign created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Campaign" }
              }
            }
          }
        }
      }
    },
    "/api/campaign/{id}": {
      "parameters": [
        { "$ref": "#/components/parameters/id" }
      ],
      "get": {
        "summary": "Get campaign by ID",
        "tags": ["campaigns"],
        "responses": {
          "200": {
            "description": "Campaign found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Campaign" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "summary": "Update campaign by ID",
        "tags": ["campaigns"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CampaignInput" },
              "example": {
                "name": "La destruccion del anillo",
                "description": "Descripcion actualizada",
                "status": "Finalizada",
                "sessions": 3
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Campaign updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Campaign" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "summary": "Delete campaign by ID",
        "tags": ["campaigns"],
        "responses": {
          "200": {
            "description": "Deletion result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MessageResponse" }
              }
            }
          }
        }
      }
    },
    "/api/mission": {
      "get": {
        "summary": "Get all missions",
        "tags": ["missions"],
        "responses": {
          "200": {
            "description": "List of missions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Mission" }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a mission",
        "tags": ["missions"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/MissionInput" },
              "example": {
                "name": "Recuperar el artefacto",
                "description": "Los aventureros deben recuperar el artefacto perdido en las ruinas",
                "missionGuide": "Guia detallada para el DM sobre como conducir la mision",
                "missionPriority": "Alta",
                "status": "Activa"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Mission created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Mission" }
              }
            }
          }
        }
      }
    },
    "/api/mission/{id}": {
      "parameters": [
        { "$ref": "#/components/parameters/id" }
      ],
      "get": {
        "summary": "Get mission by ID",
        "tags": ["missions"],
        "responses": {
          "200": {
            "description": "Mission found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Mission" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "summary": "Update mission by ID",
        "tags": ["missions"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/MissionInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Mission updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Mission" }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Delete mission by ID",
        "tags": ["missions"],
        "responses": {
          "200": {
            "description": "Deletion result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MessageResponse" }
              }
            }
          }
        }
      }
    },
    "/api/character": {
      "get": {
        "summary": "Get all characters",
        "tags": ["characters"],
        "responses": {
          "200": {
            "description": "List of characters",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Character" }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a character",
        "tags": ["characters"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CharacterInput" },
              "example": {
                "name": "Gandalf",
                "age": "elderly",
                "classType": "Wizard",
                "level": 20,
                "hitPoints": 100,
                "description": "A powerful wizard",
                "location": "Middle Earth",
                "isNPC": false
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Character created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Character" }
              }
            }
          },
          "400": {
            "description": "Character creation failed",
            "content": {
              "text/plain": {
                "schema": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "/api/character/{id}": {
      "parameters": [
        { "$ref": "#/components/parameters/id" }
      ],
      "get": {
        "summary": "Get character by ID",
        "tags": ["characters"],
        "responses": {
          "200": {
            "description": "Character found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Character" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "summary": "Update character by ID (partial)",
        "tags": ["characters"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CharacterInputPartial" },
              "example": {
                "level": 20,
                "hitPoints": 120,
                "location": "Minas Tirith"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Character updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Character" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "summary": "Delete character by ID",
        "tags": ["characters"],
        "responses": {
          "200": {
            "description": "Deletion result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MessageResponse" }
              }
            }
          }
        }
      }
    },
    "/api/group": {
      "get": {
        "summary": "Get all groups",
        "tags": ["groups"],
        "responses": {
          "200": {
            "description": "List of groups",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Group" }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a group",
        "tags": ["groups"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/GroupInput" },
              "example": {
                "name": "La Comunidad del Anillo",
                "description": "El grupo principal de aventureros",
                "members": [
                  { "id": "60d21b4667d0d8992e610c85", "name": "Gandalf", "classType": "Wizard" }
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Group created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Group" }
              }
            }
          }
        }
      }
    },
    "/api/group/{id}": {
      "parameters": [
        { "$ref": "#/components/parameters/id" }
      ],
      "get": {
        "summary": "Get group by ID",
        "tags": ["groups"],
        "responses": {
          "200": {
            "description": "Group found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Group" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "summary": "Update group by ID (partial)",
        "tags": ["groups"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/GroupInputPartial" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Group updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Group" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "summary": "Delete group by ID",
        "tags": ["groups"],
        "responses": {
          "200": {
            "description": "Deletion result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MessageResponse" }
              }
            }
          }
        }
      }
    },
    "/api/session": {
      "get": {
        "summary": "Get all sessions",
        "tags": ["sessions"],
        "responses": {
          "200": {
            "description": "List of sessions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Session" }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a session",
        "tags": ["sessions"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SessionInput" },
              "example": {
                "campaignId": "60d21b4667d0d8992e610c85",
                "title": "The Dark Forest",
                "notes": "Players found the ancient map.",
                "sessionNumber": 1,
                "date": "2024-01-15T18:00:00.000Z"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Session created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Session" }
              }
            }
          }
        }
      }
    },
    "/api/session/{id}": {
      "parameters": [
        { "$ref": "#/components/parameters/id" }
      ],
      "get": {
        "summary": "Get session by ID",
        "tags": ["sessions"],
        "responses": {
          "200": {
            "description": "Session found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Session" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "summary": "Update session by ID (partial)",
        "tags": ["sessions"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SessionInputPartial" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Session updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Session" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "summary": "Delete session by ID",
        "tags": ["sessions"],
        "responses": {
          "200": {
            "description": "Deletion result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MessageResponse" }
              }
            }
          }
        }
      }
    },
    "/api/seed": {
      "post": {
        "summary": "Seed database with sample data",
        "tags": ["seed"],
        "responses": {
          "200": {
            "description": "Seed result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MessageResponse" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "id": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "MongoDB ObjectId"
      }
    },
    "schemas": {
      "Campaign": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "status": { "type": "string", "enum": ["Activa", "Pausada", "Finalizada"] },
          "sessions": { "type": "integer" },
          "nextSessionAt": { "type": "string", "format": "date-time", "nullable": true },
          "lastSessionAt": { "type": "string", "format": "date-time", "nullable": true },
          "groups": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/GroupRef" }
          },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time", "nullable": true }
        },
        "required": ["id", "name", "description", "status", "sessions", "groups"]
      },
      "CampaignInput": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "status": { "type": "string", "enum": ["Activa", "Pausada", "Finalizada"], "default": "Activa" },
          "sessions": { "type": "integer", "default": 0 }
        },
        "required": ["name", "description"]
      },
      "Mission": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "missionGuide": { "type": "string" },
          "missionPriority": { "type": "string" },
          "status": { "type": "string", "enum": ["Activa", "Pausada", "Finalizada"] },
          "missionEvents": {
            "type": "array",
            "nullable": true,
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "difficult": { "type": "string" }
              },
              "required": ["name", "difficult"]
            }
          },
          "relatedCharacters": {
            "type": "array",
            "nullable": true,
            "items": { "$ref": "#/components/schemas/CharacterRef" }
          },
          "rewards": { "type": "string", "nullable": true },
          "startDate": { "type": "string", "format": "date-time", "nullable": true },
          "endDate": { "type": "string", "format": "date-time", "nullable": true }
        },
        "required": ["id", "name", "description", "missionGuide", "missionPriority", "status"]
      },
      "MissionInput": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 10 },
          "missionGuide": { "type": "string" },
          "missionPriority": { "type": "string" },
          "status": { "type": "string", "enum": ["Activa", "Pausada", "Finalizada"], "default": "Activa" },
          "missionEvents": {
            "type": "array",
            "nullable": true,
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "difficult": { "type": "string" }
              },
              "required": ["name", "difficult"]
            }
          },
          "relatedCharacters": {
            "type": "array",
            "nullable": true,
            "items": { "$ref": "#/components/schemas/CharacterRef" }
          },
          "rewards": { "type": "string", "nullable": true },
          "startDate": { "type": "string", "format": "date-time", "nullable": true },
          "endDate": { "type": "string", "format": "date-time", "nullable": true }
        },
        "required": ["name", "description", "missionGuide", "missionPriority"]
      },
      "Character": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "age": { "type": "string", "enum": ["child", "teenager", "adult", "elderly"] },
          "classType": { "$ref": "#/components/schemas/DnDClass" },
          "level": { "type": "integer", "minimum": 1 },
          "hitPoints": { "type": "integer", "minimum": 0 },
          "description": { "type": "string", "nullable": true },
          "location": { "type": "string", "nullable": true },
          "isNPC": { "type": "boolean", "default": false },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time", "nullable": true }
        },
        "required": ["id", "name", "age", "classType", "level", "hitPoints", "createdAt"]
      },
      "CharacterInput": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "age": { "type": "string", "enum": ["child", "teenager", "adult", "elderly"], "default": "adult" },
          "classType": { "$ref": "#/components/schemas/DnDClass" },
          "level": { "type": "integer", "minimum": 1, "default": 1 },
          "hitPoints": { "type": "integer", "minimum": 1, "default": 10 },
          "description": { "type": "string" },
          "location": { "type": "string" },
          "isNPC": { "type": "boolean", "default": false }
        },
        "required": ["name"]
      },
      "CharacterInputPartial": {
        "type": "object",
        "description": "All fields optional — only provided fields are updated",
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "age": { "type": "string", "enum": ["child", "teenager", "adult", "elderly"] },
          "classType": { "$ref": "#/components/schemas/DnDClass" },
          "level": { "type": "integer", "minimum": 1 },
          "hitPoints": { "type": "integer", "minimum": 1 },
          "description": { "type": "string" },
          "location": { "type": "string" },
          "isNPC": { "type": "boolean" }
        }
      },
      "Group": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "members": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/GroupMember" }
          },
          "createdAt": { "type": "string", "format": "date-time", "nullable": true },
          "updatedAt": { "type": "string", "format": "date-time", "nullable": true }
        },
        "required": ["id", "name", "description", "members"]
      },
      "GroupInput": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "members": {
            "type": "array",
            "default": [],
            "items": { "$ref": "#/components/schemas/GroupMember" }
          }
        },
        "required": ["name", "description"]
      },
      "GroupInputPartial": {
        "type": "object",
        "description": "All fields optional — only provided fields are updated",
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "members": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/GroupMember" }
          }
        }
      },
      "Session": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "campaignId": { "type": "string" },
          "title": { "type": "string" },
          "notes": { "type": "string" },
          "sessionNumber": { "type": "integer", "minimum": 1 },
          "date": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "campaignId", "title", "notes", "sessionNumber", "date"]
      },
      "SessionInput": {
        "type": "object",
        "properties": {
          "campaignId": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "notes": { "type": "string", "default": "" },
          "sessionNumber": { "type": "integer", "minimum": 1 },
          "date": { "type": "string", "format": "date-time" }
        },
        "required": ["campaignId", "title", "sessionNumber", "date"]
      },
      "SessionInputPartial": {
        "type": "object",
        "description": "All fields optional — only provided fields are updated",
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "notes": { "type": "string" },
          "sessionNumber": { "type": "integer", "minimum": 1 },
          "date": { "type": "string", "format": "date-time" }
        }
      },
      "GroupMember": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "classType": { "$ref": "#/components/schemas/DnDClass" }
        },
        "required": ["id", "name", "classType"]
      },
      "GroupRef": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" }
        },
        "required": ["id", "name"]
      },
      "CharacterRef": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" }
        },
        "required": ["id", "name"]
      },
      "DnDClass": {
        "type": "string",
        "enum": ["Barbarian", "Bard", "Cleric", "Druid", "Fighter", "Monk", "Paladin", "Ranger", "Rogue", "Sorcerer", "Warlock", "Wizard", "Artificer", "Blood Hunter", "Normal", "Other"],
        "default": "Normal"
      },
      "MessageResponse": {
        "type": "object",
        "properties": {
          "message": { "type": "string" }
        },
        "required": ["message"]
      }
    },
    "responses": {
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
